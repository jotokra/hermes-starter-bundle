  "active_provider": "<<your-provider-name>>",
  "providers": {
    "<<your-provider-name>>": {
      "provider": "<<your-provider-name>>",
      "inference_base_url": "<<https://api.example.com/v1>>",
      "api_key": "<<your-api-key-here>>"
    }
  }
}
