{
  "_comment": "DO NOT commit a real auth.json. This file is the TEMPLATE that auth.json.template.example is generated from. To set up your own auth, either: (1) run `hermes login` and the agent will populate ~/.hermes/auth.json for you, or (2) copy auth.json.template to ~/.hermes/auth.json and fill in your own provider credentials. Secrets NEVER go in git.",
  "_usage": "cp auth.json.template ~/.hermes/auth.json && edit ~/.hermes/auth.json with your real keys",
